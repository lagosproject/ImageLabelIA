# ==============================================================================
# Git Ignore Configuration for Image Label IA
# Stack: Angular, Tauri (Rust), Python
# ==============================================================================

# OS / System Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk
*.sys
*.tmp

# Environment Variables & Secrets (CRITICAL)
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
.envrc
*.pem
*.key
*.cert
*.pfx
*.p12
*.crt
credentials.json
secrets.json
*token*
*apikey*

# Node / Angular
# ------------------------------------------------------------------------------
node_modules/
/dist/
/.angular/
.npm/
/connect.lock
/package-lock.json
/yarn.lock
# /pnpm-lock.yaml
/bun.lockb
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
.cache/

# Rust / Tauri
# ------------------------------------------------------------------------------
/src-tauri/target/
/src-tauri/gen/
/src-tauri/binaries/
/src-tauri/resources/*.onnx
/src-tauri/resources/*.onnx.data
/src-tauri/resources/*_labels.json
*.pdb
*.swp
*.bak
# Cargo.lock
# (Optional: Keep Cargo.lock for binary applications, but since it is a Tauri app,
# we might want to check it in. However, standard Rust convention often keeps Cargo.lock.
# Let's not ignore Cargo.lock by default to ensure reproducible builds, but ignore target/)

