# ==============================================================================
# Image Label IA - Environment Variables Template
# Copy this file to `.env` in the same directory and fill in your values.
# DO NOT commit your `.env` file containing actual secrets to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Tauri & Frontend Port Settings
# ------------------------------------------------------------------------------
# The port where the Angular dev server runs and Tauri listens
PORT=1420
TAURI_DEV_HOST=localhost

# ------------------------------------------------------------------------------
# 2. AI Model & Hugging Face Hub Settings
# ------------------------------------------------------------------------------
# If you are downloading models from private Hugging Face repositories or hit
# rate limits, provide your Hugging Face API read token here.
# Retrieve from: https://huggingface.co/settings/tokens
HF_TOKEN=<YOUR_HUGGINGFACE_READ_TOKEN_HERE>

# ------------------------------------------------------------------------------
# 3. ONNX Runtime & Inference Configuration
# ------------------------------------------------------------------------------
# Configures the execution provider for the ONNX Runtime library (ort).
# Options: cpu, cuda, tensorrt, directml (Windows), coreml (macOS)
ORT_EXECUTION_PROVIDER=cpu

# Log level for ONNX Runtime/Tauri backend (error, warn, info, debug, trace)
RUST_LOG=info

# ------------------------------------------------------------------------------
# 4. Python Environment Settings
# ------------------------------------------------------------------------------
# Path to your local Python executable (if not default system path or inside a venv)
PYTHON_EXECUTABLE=python3
